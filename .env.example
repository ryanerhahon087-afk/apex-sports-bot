# APEX/SPORTS BOT — Environment Variables
# Set these in Railway dashboard under Variables

# Kalshi API (same keys as BTC bot)
KALSHI_API_KEY_ID=your_key_id_here
KALSHI_PRIVATE_KEY=your_pem_key_here_with_newlines_as_\n

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_key_here

# Bot Settings
PAPER_MODE=true
STARTING_BALANCE=100.00
DASHBOARD_PASSWORD=your_password_here

# Database (Railway volume mount at /storage)
DB_PATH=/storage/sports_bot.db

# Railway sets this automatically
PORT=8081
